# Local development: copy this file to `.env` and fill in values from
# Supabase Dashboard → Project Settings → API (Project URL + publishable/anon key).
# Do not commit `.env` or paste production keys into tracked files.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
